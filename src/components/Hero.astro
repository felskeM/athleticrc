---
import Container from "./Container.astro";
import Button from "./Button.astro";
import StatPill from "./StatPill.astro";
---

<section class="section-padding relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-0 grid-sheen opacity-[0.08]"></div>
    <div class="absolute left-[-10%] top-16 h-72 w-72 rounded-full bg-[var(--arc-blue)]/20 blur-3xl"></div>
    <div class="absolute bottom-0 right-[-8%] h-80 w-80 rounded-full bg-[var(--arc-blue)]/12 blur-3xl"></div>
  </div>

  <Container>
    <div class="grid items-center gap-10 lg:grid-cols-[1.02fr_0.98fr]">
      <div class="relative z-10">
        <p class="eyebrow">Performance Flooring Systems</p>
        <h1 class="mt-5 max-w-5xl text-5xl font-semibold leading-[0.94] tracking-tight text-[var(--arc-white)] md:text-7xl xl:text-[5.25rem]">
          Rubber flooring built for commercial durability, technical clarity, and serious environments.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--arc-muted)] md:text-xl">
          AthleticRC is the business-to-business information hub for product formats, technical documentation,
          installation guidance, and specification-driven flooring systems.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/products">Explore Products</Button>
          <Button href="/resources" variant="secondary">Browse Resources</Button>
        </div>

        <div class="mt-10 grid max-w-3xl gap-4 sm:grid-cols-3">
          <StatPill label="Formats" value="Rolls, Tile, Sheets" />
          <StatPill label="Focus" value="B2B Specification" />
          <StatPill label="Resources" value="Install + Spec PDFs" />
        </div>
      </div>

      <div class="relative z-10">
        <div class="grid gap-4 md:grid-cols-[1.2fr_0.8fr]">
          <div class="card-shell relative overflow-hidden p-3">
            <div class="image-frame aspect-[4/5] rounded-[1.35rem]">
              <img src="/images/hero/arc-hero-main.jpg" alt="Athletic Rubber Converting facility or flooring operations" class="h-full w-full object-cover" />
            </div>
            <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(28,63,142,0.22),transparent_32%)]"></div>
            <div class="absolute bottom-7 left-7 right-7 rounded-[1.35rem] border border-white/10 bg-[rgba(10,7,8,0.72)] p-5 backdrop-blur-md">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--arc-accent-2)]">AthleticRC</p>
              <p class="mt-2 text-xl font-semibold text-[var(--arc-white)]">Built for technical product storytelling.</p>
              <p class="mt-2 text-sm leading-7 text-[var(--arc-muted)]">
                Use your facility, process, and installed-environment imagery here until final product photography is ready.
              </p>
            </div>
          </div>

          <div class="grid gap-4">
            <div class="card-shell p-3">
              <div class="image-frame aspect-[4/3] rounded-[1.35rem]">
                <img src="/images/hero/arc-hero-secondary.jpg" alt="Material or process detail for Athletic Rubber Converting" class="h-full w-full object-cover" />
              </div>
            </div>

            <div class="card-shell relative overflow-hidden p-5">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(28,63,142,0.25),transparent_36%)]"></div>
              <div class="relative">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--arc-muted)]">Featured System</p>
                <h2 class="mt-3 text-3xl font-semibold text-[var(--arc-white)]">VersaTREAD</h2>
                <p class="mt-4 text-sm leading-7 text-[var(--arc-muted)]">
                  A resilient line with custom-length rolls and modular tile options for athletic and commercial use.
                </p>
                <div class="mt-5 grid gap-3">
                  <div class="panel-shell p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-[var(--arc-muted)]">Roll Formats</p>
                    <p class="mt-2 text-base font-semibold text-[var(--arc-white)]">4' Wide × Custom Length</p>
                  </div>
                  <div class="panel-shell p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-[var(--arc-muted)]">Tile Formats</p>
                    <p class="mt-2 text-base font-semibold text-[var(--arc-white)]">2' × 2' Puzzle Tile</p>
                  </div>
                </div>
                <div class="mt-5">
                  <Button href="/products/versatread">View Product</Button>
                </div>
              </div>
  </Container>
</section>