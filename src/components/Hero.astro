---
import Container from "./Container.astro";
import Button from "./Button.astro";
---

<section class="section-padding overflow-hidden">
  <Container>
    <div class="grid items-center gap-12 lg:grid-cols-[1.2fr_0.8fr]">
      <div>
        <p class="eyebrow">Performance Flooring Systems</p>
        <h1 class="mt-4 max-w-4xl text-5xl font-semibold tracking-tight text-white md:text-7xl">
          Spec-driven rubber flooring for athletic, commercial, and high-traffic environments.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-white/70">
          AthleticRC serves as an informational hub for product formats, technical resources, installation guidance,
          and business-to-business inquiries.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/products">View Products</Button>
          <Button href="/resources" variant="secondary">Download Resources</Button>
        </div>
      </div>

      <div class="card-shell relative min-h-[420px] overflow-hidden p-6">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(247,207,61,0.18),transparent_40%)]"></div>
        <div class="relative flex h-full flex-col justify-between rounded-[1.5rem] border border-white/10 bg-black/30 p-6">
          <div>
            <p class="text-sm font-medium text-white/60">Featured System</p>
            <h2 class="mt-3 text-3xl font-semibold text-white">VersaTREAD</h2>
            <p class="mt-4 text-sm leading-7 text-white/70">
              Rolls, tile, and sheet formats built for traction, durability, and clean commercial presentation.
            </p>
          </div>
          <div class="grid gap-3 text-sm text-white/80 sm:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Rolls</div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Puzzle Tile</div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Sheets</div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Technical Resources</div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>