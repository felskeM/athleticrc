---
import Container from "./Container.astro";
import Button from "./Button.astro";
---

<section class="section-padding">
  <Container>
    <div class="card-shell relative overflow-hidden p-8 md:p-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(28,63,142,0.26),transparent_34%)]"></div>
      <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <p class="eyebrow">Next Step</p>
          <h2 class="mt-3 max-w-3xl text-3xl font-semibold tracking-tight text-[var(--arc-white)] md:text-5xl">
            Need specs, installation documents, or product direction?
          </h2>
          <p class="mt-4 max-w-2xl text-base leading-7 text-[var(--arc-muted)] md:text-lg">
            Push dealers, contractors, architects, and commercial buyers toward a clear information request path instead of a generic contact page.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <Button href="/contact">Request Information</Button>
          <Button href="/resources" variant="secondary">View Resources</Button>
        </div>
      </div>
    </div>
  </Container>
</section>