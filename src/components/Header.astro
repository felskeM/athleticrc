---
import Container from "./Container.astro";
import Button from "./Button.astro";

const links = [
  { href: "/", label: "Home" },
  { href: "/products", label: "Products" },
  { href: "/resources", label: "Resources" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[rgba(10,7,8,0.72)] backdrop-blur-xl">
  <Container>
    <div class="flex min-h-[4.75rem] items-center justify-between gap-6">
      <a href="/" class="flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--arc-white)]">
        <span class="relative inline-flex h-3.5 w-3.5 items-center justify-center">
          <span class="absolute inline-block h-3.5 w-3.5 rounded-full bg-[var(--arc-blue)] opacity-25 blur-[4px]"></span>
          <span class="relative inline-block h-2.5 w-2.5 rounded-full bg-[var(--arc-blue)]"></span>
        </span>
        AthleticRC
      </a>

      <nav class="hidden items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-2 md:flex">
        {links.map((link) => (
          <a href={link.href} class="rounded-full px-3 py-2 text-sm text-[var(--arc-white)]/72 transition hover:bg-white/[0.05] hover:text-[var(--arc-white)]">
            {link.label}
          </a>
        ))}
      </nav>

      <div class="hidden md:block">
        <Button href="/contact">Request Information</Button>
      </div>
    </div>
  </Container>
</header>