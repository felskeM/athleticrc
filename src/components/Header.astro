---
import Container from "./Container.astro";
import Button from "./Button.astro";

const links = [
  { href: "/", label: "Home" },
  { href: "/products", label: "Products" },
  { href: "/resources", label: "Resources" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-black/50 backdrop-blur-xl">
  <Container>
    <div class="flex min-h-18 items-center justify-between gap-6">
      <a href="/" class="flex items-center gap-3 text-sm font-semibold tracking-[0.18em] text-white uppercase">
        <span class="inline-block h-3 w-3 rounded-full bg-[var(--arc-blue)]/400"></span>
        AthleticRC
      </a>

      <nav class="hidden items-center gap-6 md:flex">
        {links.map((link) => (
          <a href={link.href} class="text-sm text-white/75 transition hover:text-white">{link.label}</a>
        ))}
      </nav>

      <div class="hidden md:block">
        <Button href="/contact">Request Information</Button>
      </div>
    </div>
  </Container>
</header>