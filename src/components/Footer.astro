---
import Container from "./Container.astro";
---

<footer class="border-t border-white/10 bg-black/30 py-10 backdrop-blur-md">
  <Container>
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--arc-white)]">
          Athletic Rubber Converting
        </p>
        <p class="mt-2 max-w-2xl text-sm leading-7 text-[var(--arc-muted)]">
          Informational product site for commercial and athletic flooring systems, specification documents,
          installation resources, and business-to-business inquiries.
        </p>
      </div>

      <div class="text-sm text-[var(--arc-muted)]/80">© {new Date().getFullYear()} AthleticRC</div>
    </div>
  </Container>
</footer>