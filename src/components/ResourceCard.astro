---
interface Props {
  href: string;
  title: string;
  summary: string;
  type: string;
  product: string;
}

const { href, title, summary, type, product } = Astro.props;
---

<a href={href} class="card-shell block p-5 transition hover:bg-white/8" target="_blank" rel="noreferrer">
  <div class="flex flex-wrap items-center gap-2">
    <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-white/70">{type}</span>
    <span class="rounded-full bg-yellow-300/10 px-3 py-1 text-xs text-yellow-200">{product}</span>
  </div>
  <h3 class="mt-4 text-xl font-semibold text-white">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-white/70">{summary}</p>
  <p class="mt-4 text-sm font-medium text-yellow-200">Open PDF →</p>
</a>