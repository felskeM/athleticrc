---
interface Props {
  href: string;
  title: string;
  summary: string;
  type: string;
  product: string;
}

const { href, title, summary, type, product } = Astro.props;
---

<a href={href} class="card-shell block p-5 transition duration-200 hover:-translate-y-1 hover:border-[var(--arc-blue)]/30 hover:bg-white/[0.06]" target="_blank" rel="noreferrer">
  <div class="flex flex-wrap items-center gap-2">
    <span class="rounded-full bg-white/8 px-3 py-1 text-xs uppercase tracking-[0.12em] text-[var(--arc-muted)]">{type}</span>
    <span class="rounded-full bg-[var(--arc-blue)]/10 px-3 py-1 text-xs uppercase tracking-[0.12em] text-[var(--arc-accent-2)]">{product}</span>
  </div>
  <h3 class="mt-4 text-xl font-semibold text-[var(--arc-white)]">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-[var(--arc-muted)]">{summary}</p>
  <p class="mt-4 text-sm font-semibold text-[var(--arc-accent-2)]">Open PDF →</p>
</a>