---
interface Props {
  href: string;
  title: string;
  summary: string;
  tags?: string[];
}

const { href, title, summary, tags = [] } = Astro.props;
---

<a href={href} class="card-shell block p-6 transition hover:-translate-y-1 hover:bg-white/8">
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-2xl font-semibold text-white">{title}</h3>
    <span class="rounded-full border border-[var(--arc-blue)]/30 bg-[var(--arc-blue)]/10 px-3 py-1 text-xs font-medium text-[var(--arc-blue)]">
      Product
    </span>
  </div>
  <p class="mt-4 text-sm leading-7 text-white/70">{summary}</p>
  {tags.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-white/70">{tag}</span>
      ))}
    </div>
  )}
</a>