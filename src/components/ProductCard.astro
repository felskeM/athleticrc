---
interface Props {
  href: string;
  title: string;
  summary: string;
  tags?: string[];
}

const { href, title, summary, tags = [] } = Astro.props;
---

<a href={href} class="card-shell block p-6 transition duration-200 hover:-translate-y-1 hover:border-[var(--arc-blue)]/30 hover:bg-white/[0.06]">
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-2xl font-semibold text-[var(--arc-white)]">{title}</h3>
    <span class="rounded-full border border-[var(--arc-blue)]/30 bg-[var(--arc-blue)]/10 px-3 py-1 text-xs font-medium uppercase tracking-[0.12em] text-[var(--arc-accent-2)]">
      Product
    </span>
  </div>

  <p class="mt-4 text-sm leading-7 text-[var(--arc-muted)]">{summary}</p>

  {tags.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-xs text-[var(--arc-muted)]">{tag}</span>
      ))}
    </div>
  )}
</a>