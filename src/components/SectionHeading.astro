---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-5xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-white/70 md:text-lg">{description}</p>}
</div>